rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /croix/{document} {
      allow create: if request.auth != null;
      allow read: if true;
      allow write: if request.auth.uid == resource.data.created_by;
      allow delete: if request.auth.uid == resource.data.created_by;
    }

    match /user/{document} {
      allow create: if request.auth.uid == request.resource.data.uid;
      allow read: if request.auth.uid == resource.data.uid;
      allow write: if request.auth.uid == resource.data.uid;
      allow delete: if request.auth.uid == resource.data.uid;
    }

    match /prediction/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth.uid == resource.data.created_by;
    }

    match /resultats/{document} {
      allow create: if request.auth != null;
      allow read: if true;
      allow write: if request.auth.uid == resource.data.created_by;
      allow delete: if request.auth.uid == resource.data.created_by;
    }

    match /prediction/{parent}/userStars/{document} {
      allow create: if false;
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    match /{path=**}/userStars/{document} {
      allow read: if true;
    }


    match /bingo/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if false;
      allow delete: if false;
    }

    match /bingo/{parent}/bingostats/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if false;
      allow delete: if false;
    }

    match /{path=**}/bingostats/{document} {
      allow read: if true;
    }


    match /youtubeLinks/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if false;
      allow delete: if false;
    }

    match /settings/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if false;
      allow delete: if false;
    }

    match /postText/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if false;
      allow delete: if false;
    }
  }
}
